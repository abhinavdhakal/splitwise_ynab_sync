name: Splitwise YNAB Sync (Hourly)

# Alternative workflow for hourly syncing
# To use this instead of the 12-hour schedule:
# 1. Delete or rename the main sync.yml file
# 2. Rename this file to sync.yml

on:
  # Scheduled run every hour
  schedule:
    - cron: '0 * * * *'
  
  # Manual trigger option
  workflow_dispatch:
    inputs:
      sync_days:
        description: 'Number of days to sync (default: 15)'
        required: false
        default: '15'
        type: string

jobs:
  sync:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
    
    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.11'
    
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt
    
    - name: Run Splitwise YNAB Sync
      env:
        SPLITWISE_API_KEY: ${{ secrets.SPLITWISE_API_KEY }}
        YNAB_TOKEN: ${{ secrets.YNAB_TOKEN }}
        YNAB_BUDGET_NAME: ${{ secrets.YNAB_BUDGET_NAME }}
        YNAB_ACCOUNT_NAME: ${{ secrets.YNAB_ACCOUNT_NAME }}
        SYNC_DAYS: ${{ github.event.inputs.sync_days || '15' }}
      run: |
        python splitwise_ynab_sync.py --once --days ${{ github.event.inputs.sync_days || '15' }}
    
    - name: Upload logs (on failure)
      if: failure()
      uses: actions/upload-artifact@v3
      with:
        name: sync-logs-hourly
        path: "*.log"
        retention-days: 7